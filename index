const colorScales = {
  composite: {
    label: "AI impact (composite)",
    ramp: ["#E8E6DE","#C0DD97","#97C459","#639922","#3B6D11"],
    text: ["#4A4A45","#27500A","#173404","#EAF3DE","#EAF3DE"]
  },
  c: {
    label: "Complementarity",
    ramp: ["#E6F1FB","#85B7EB","#378ADD","#185FA5","#0C447C"],
    text: ["#0C447C","#042C53","#E6F1FB","#E6F1FB","#E6F1FB"]
  },
  a: {
    label: "Augmentation",
    ramp: ["#FAEEDA","#FAC775","#EF9F27","#BA7517","#854F0B"],
    text: ["#633806","#412402","#412402","#FAEEDA","#FAEEDA"]
  },
  s: {
    label: "Substitutivity",
    ramp: ["#FCEBEB","#F09595","#E24B4A","#A32D2D","#791F1F"],
    text: ["#791F1F","#501313","#FCEBEB","#FCEBEB","#FCEBEB"]
  }
};

let activeDim = "composite";
let currentPath = [];

function getScore(node, dim) {
  if (node.roles) {
    const totalHc = node.roles.reduce((s, r) => s + r.hc, 0);
    if (dim === "composite") return node.roles.reduce((s, r) => s + r.hc * ((r.c + r.a + r.s) / 3), 0) / totalHc;
    return node.roles.reduce((s, r) => s + r.hc * r[dim], 0) / totalHc;
  }
  if (node.children) {
    const totalHc = node.children.reduce((s, c) => s + c.hc, 0);
    return node.children.reduce((s, c) => s + c.hc * getScore(c, dim), 0) / totalHc;
  }
  if (dim === "composite") return (node.c + node.a + node.s) / 3;
  return node[dim];
}

function getColorIdx(val) {
  if (val <= 2.0) return 0;
  if (val <= 2.8) return 1;
  if (val <= 3.4) return 2;
  if (val <= 4.0) return 3;
  return 4;
}

function getSignal(c, a, s) {
  if (c >= 4.0 && a >= 3.8 && s >= 2.8) return { label: "Transform", bg: "var(--transform-bg)", color: "var(--transform-tx)" };
  if (a >= 3.5 && s <= 2.2) return { label: "Reskill", bg: "var(--reskill-bg)", color: "var(--reskill-tx)" };
  if (c >= 3.5 && s <= 2.5) return { label: "Tool", bg: "var(--tool-bg)", color: "var(--tool-tx)" };
  return { label: "Protect", bg: "var(--protect-bg)", color: "var(--protect-tx)" };
}

function squarify(items, x, y, w, h) {
  const total = items.reduce((s, i) => s + i.hc, 0);
  if (!items.length || total === 0) return [];
  const rects = [];
  let cx = x, cy = y, cw = w, ch = h;
  const sorted = [...items].sort((a, b) => b.hc - a.hc);
  let remaining = total;
  let i = 0;

  while (i < sorted.length) {
    const horiz = cw >= ch;
    const side = horiz ? ch : cw;
    let row = [], rowArea = 0;

    function worst(row, rowArea) {
      const s = rowArea / remaining * (horiz ? cw : ch);
      if (s === 0) return Infinity;
      let mx = 0;
      row.forEach(r => {
        const area = (r.hc / remaining) * cw * ch;
        const len = area / s;
        mx = Math.max(mx, Math.max(s / len, len / s));
      });
      return mx;
    }

    while (i < sorted.length) {
      const item = sorted[i];
      const newRow = [...row, item];
      const newArea = rowArea + item.hc;
      if (row.length === 0 || worst(newRow, newArea) <= worst(row, rowArea)) {
        row = newRow;
        rowArea = newArea;
        i++;
      } else break;
    }

    const stripFrac = rowArea / remaining;
    const stripSize = horiz ? Math.round(cw * stripFrac) : Math.round(ch * stripFrac);
    let offset = horiz ? cy : cx;

    row.forEach(r => {
      const frac = r.hc / rowArea;
      if (horiz) {
        const ih = Math.round(ch * frac);
        rects.push({ ...r, rx: cx, ry: offset, rw: stripSize, rh: ih });
        offset += ih;
      } else {
        const iw = Math.round(cw * frac);
        rects.push({ ...r, rx: offset, ry: cy, rw: iw, rh: stripSize });
        offset += iw;
      }
    });

    remaining -= rowArea;
    if (horiz) { cx += stripSize; cw -= stripSize; }
    else { cy += stripSize; ch -= stripSize; }
  }
  return rects;
}

function getCurrentNode() {
  let node = org;
  for (const idx of currentPath) {
    node = (node.children || node.roles)[idx];
  }
  return node;
}

function getChildren(node) {
  return node.children || node.roles || [];
}

function render() {
  const scale = colorScales[activeDim];
  const node = getCurrentNode();
  const children = getChildren(node);

  const orgC = getScore(org, "c");
  const orgA = getScore(org, "a");
  const orgS = getScore(org, "s");
  const orgComp = (orgC + orgA + orgS) / 3;

  document.getElementById("summaryRow").innerHTML = `
    <div class="stat-card featured">
      <div class="num" style="color:var(--brand)">${orgComp.toFixed(1)}</div>
      <div class="label">Org AI impact</div>
      <div class="explain">Composite (1-5 scale)</div>
    </div>
    <div class="stat-card">
      <div class="num" style="color:var(--c-color)">${orgC.toFixed(1)}</div>
      <div class="label">Complementarity</div>
      <div class="explain">AI enhances capability</div>
    </div>
    <div class="stat-card">
      <div class="num" style="color:var(--a-color)">${orgA.toFixed(1)}</div>
      <div class="label">Augmentation</div>
      <div class="explain">Workflow change needed</div>
    </div>
    <div class="stat-card">
      <div class="num" style="color:var(--s-color)">${orgS.toFixed(1)}</div>
      <div class="label">Substitutivity</div>
      <div class="explain">Displacement potential</div>
    </div>
  `;

  document.getElementById("dimPills").innerHTML = Object.entries(colorScales).map(([k, v]) =>
    `<button class="pill ${k === activeDim ? 'active' : ''}" onclick="activeDim='${k}';render()">${v.label}</button>`
  ).join("");

  document.getElementById("legend").innerHTML =
    `<span>Low</span>` +
    scale.ramp.map(c => `<div class="legend-swatch" style="background:${c}"></div>`).join("") +
    `<span>High</span>`;

  let bc = `<span class="crumb" onclick="currentPath=[];render()">BDO USA</span>`;
  let trail = org;
  currentPath.forEach((idx, i) => {
    trail = (trail.children || trail.roles)[idx];
    const ps = JSON.stringify(currentPath.slice(0, i + 1));
    bc += `<span class="sep">/</span><span class="crumb" onclick="currentPath=${ps};render()">${trail.name}</span>`;
  });
  document.getElementById("breadcrumb").innerHTML = bc;

  const container = document.getElementById("treemap");
  const W = container.offsetWidth || 1136;
  const H = Math.max(340, Math.min(520, Math.round(W * 0.5)));
  container.style.height = H + "px";

  const gap = 3;
  const rects = squarify(children, 0, 0, W, H);

  container.innerHTML = rects.map((r) => {
    const score = getScore(r, activeDim);
    const ci = getColorIdx(score);
    const bg = scale.ramp[ci];
    const tc = scale.text[ci];
    const canDrill = r.children || r.roles;
    const realIdx = children.findIndex(c => c.name === r.name);
    const x = r.rx + gap;
    const y = r.ry + gap;
    const w = Math.max(0, r.rw - gap * 2);
    const h = Math.max(0, r.rh - gap * 2);

    let inner = "";
    if (w > 55 && h > 28) inner += `<div class="tm-name" style="color:${tc}">${r.name}</div>`;
    if (w > 75 && h > 48) inner += `<div class="tm-meta" style="color:${tc}">${r.hc.toLocaleString()} people</div>`;
    if (w > 55 && h > 68) inner += `<div class="tm-score" style="color:${tc}">${score.toFixed(1)}</div>`;

    const action = canDrill
      ? `currentPath.push(${realIdx});render();`
      : `showDetail(${realIdx});`;

    return `<div class="tm-node" style="left:${x}px;top:${y}px;width:${w}px;height:${h}px;background:${bg};" onclick="${action}">
      <div class="tm-inner">${inner}</div></div>`;
  }).join("");

  const isLeafLevel = !children.some(c => c.children || c.roles);
  if (isLeafLevel) {
    const largest = children.reduce((best, c) => c.hc > best.hc ? c : best, children[0]);
    showDetail(children.indexOf(largest));
  } else {
    document.getElementById("detailPanel").innerHTML = "";
  }
}

function showDetail(idx) {
  const node = getCurrentNode();
  const children = getChildren(node);
  const item = children[idx];
  if (!item) return;

  const roles = item.roles || [item];
  const c = getScore(item, "c");
  const a = getScore(item, "a");
  const s = getScore(item, "s");
  const comp = (c + a + s) / 3;

  const signals = {};
  roles.forEach(r => {
    const sig = getSignal(r.c || c, r.a || a, r.s || s);
    if (!signals[sig.label]) signals[sig.label] = { ...sig, hc: 0 };
    signals[sig.label].hc += (r.hc || 0);
  });

  let sigTags = Object.values(signals).map(s =>
    `<span class="signal-tag" style="background:${s.bg};color:${s.color}">${s.label}: ${s.hc.toLocaleString()} people</span>`
  ).join("");

  const sortedRoles = [...roles].sort((a, b) => getScore(b, activeDim) - getScore(a, activeDim));
  let bars = sortedRoles.map(r => {
    const rv = getScore(r, activeDim);
    const ci = getColorIdx(rv);
    const bg = colorScales[activeDim].ramp[ci];
    const sig = getSignal(r.c || c, r.a || a, r.s || s);
    return `<div class="bar-row">
      <div class="bar-label">${r.name}</div>
      <div class="bar-hc">${r.hc.toLocaleString()}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${(rv / 5) * 100}%;background:${bg}"></div></div>
      <div class="bar-val">${rv.toFixed(1)}</div>
      <div class="bar-signal"><span class="signal-tag" style="background:${sig.bg};color:${sig.color};font-size:11px;padding:2px 6px">${sig.label}</span></div>
    </div>`;
  }).join("");

  document.getElementById("detailPanel").innerHTML = `
    <div class="detail-panel">
      <div class="dp-header">
        <div class="dp-title">${item.name}</div>
        <div class="dp-hc">${item.hc.toLocaleString()} professionals</div>
      </div>
      <div class="dp-scores">
        <div class="dp-score scomp"><div class="v">${comp.toFixed(1)}</div><div class="l">Composite</div></div>
        <div class="dp-score sc"><div class="v">${c.toFixed(1)}</div><div class="l">Complementarity</div></div>
        <div class="dp-score sa"><div class="v">${a.toFixed(1)}</div><div class="l">Augmentation</div></div>
        <div class="dp-score ss"><div class="v">${s.toFixed(1)}</div><div class="l">Substitutivity</div></div>
      </div>
      <div class="signal-tags">${sigTags}</div>
      <div class="bar-section-label">Roles by ${colorScales[activeDim].label.toLowerCase()}</div>
      ${bars}
    </div>
  `;
}

